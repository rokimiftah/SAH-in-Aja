# ! ==============================================================================
# ! SAH-in Aja! - Environment Variables
# ! ==============================================================================
# ! Copy this file to .env.local and fill in your values
# ! NEVER commit .env.local to git!
# ! ==============================================================================

# ------------------------------------------------------------------------------
# CONVEX (Backend-as-a-Service) - Set on .env.local
# ------------------------------------------------------------------------------
# Get from: https://dashboard.convex.dev
# Run `npx convex dev` to get these values automatically

# Frontend: Convex deployment URL
CONVEX_DEPLOYMENT=dev:
PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ------------------------------------------------------------------------------
# Vapi (Voice)
# ------------------------------------------------------------------------------
# Provider: Vapi.ai
# Get from: https://dashboard.vapi.ai/org/api-keys
# Used for: Simulasi Audit Halal

PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key



# ! ------------------------------------------------------------------------------
# ! CONVEX DASHBOARD ENVIRONMENT VARIABLES
# ! ------------------------------------------------------------------------------
# ! Set these in Convex Dashboard > Settings > Environment Variables
# ! https://dashboard.convex.dev/t/username/yourproject/urlproject/settings/environment-variables
# ! ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# OAUTH (Authentication)
# ------------------------------------------------------------------------------
# GitHub: https://github.com/settings/developers
# Google: https://console.cloud.google.com/auth/overview

AUTH_GOOGLE_ID=google-client-id
AUTH_GOOGLE_SECRET=google-client-secret

# JWT Configuration
# Generate with: npx @convex-dev/auth (or node generateKeys.mjs)
# Docs: https://labs.convex.dev/auth/setup/manual
JWKS={"keys":[...]}
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----...

# Site URLs for OAuth callbacks
CUSTOM_AUTH_SITE_URL=https://your-domain.com
SITE_URL=https://your-domain.com

# ------------------------------------------------------------------------------
# LLM API (Vision & Text)
# ------------------------------------------------------------------------------
# Provider: CanopyWave (OpenAI-compatible API)
# Endpoint: https://inference.canopywave.io/v1
# Used for: Siap Halal (Vision AI), Dokumen Halal & Asisten Halal (Text AI)
# Models: xiaomimimo/mimo-v2-flash (text), moonshotai/kimi-k2.5 (vision)

LLM_API_KEY=your_canopywave_api_key
LLM_API_URL=https://inference.canopywave.io/v1
LLM_MODEL_TEXT=xiaomimimo/mimo-v2-flash
LLM_MODEL_VISION=moonshotai/kimi-k2.5

# ------------------------------------------------------------------------------
# RESEND API (Email)
# ------------------------------------------------------------------------------
# Get from: https://resend.com/api-keys
# Used for: Authentication (magic links), notifications
# Free tier: 100 emails/day

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# MAYAR.ID (Payment Gateway) - Set in Convex Dashboard
# ------------------------------------------------------------------------------
# Provider: Mayar.id
# Get API Key from: https://web.mayar.id/api-keys (production) or https://web.mayar.club/api-keys (sandbox)
# Used for: Top-Up Kredit AI payment processing
# Docs: https://docs.mayar.id

# Mayar API Key
# Production: https://web.mayar.id/api-keys
# Sandbox: https://web.mayar.club/api-keys
MAYAR_API_KEY=your_mayar_api_key_here

# Set to "true" for sandbox/testing (uses api.mayar.club)
# Omit or set to "false" for production (uses api.mayar.id)
MAYAR_SANDBOX=true

# Payment Link ID used for coupon validation endpoint (/hl/v1/coupon/validate)
# Get it from Mayar dashboard/API list payment request and use the UUID `id`
MAYAR_COUPON_PAYMENT_LINK_ID=your_payment_link_id_for_coupon_validation

# Webhook secret for security verification (generate with: openssl rand -hex 32)
MAYAR_WEBHOOK_SECRET=your_random_webhook_secret_here

# Webhook URL to configure in Mayar Dashboard (Integration -> Webhook):
# https://your-project.convex.site/mayar-webhook?token=YOUR_MAYAR_WEBHOOK_SECRET
